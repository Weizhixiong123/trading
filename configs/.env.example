# 企业微信群机器人 key
WECOM_KEY=PUT_YOUR_WECOM_KEY_HERE

# 扫描与推送
SCAN_INTERVAL_SEC=900
ALERT_COOLDOWN_SEC=14400
REQ_TIMEOUT=8
CONCURRENCY=30

# 候选池
MIN_24H_QUOTE_VOL=5000000
TOP_N_BY_VOLUME=180
MAX_24H_PRICE_PCT=35.0

# K线结构
KLINE_INTERVAL=4h
KLINE_LIMIT=120
STRUCTURE_LOOKBACK=20
EMA_FAST_PERIOD=20
EMA_MID_PERIOD=50
EMA_SLOW_PERIOD=100

# A级: 4H启动确认
A_MIN_4H_PRICE_PCT=2.0
A_MAX_4H_PRICE_PCT=8.0
A_MIN_4H_VOL_RATIO=1.5
A_MAX_DIST_ABOVE_EMA_FAST_PCT=12.0
A_MIN_OI_4H_PCT=2.0

# B级: 4H低位蓄势
B_MAX_4H_PRICE_PCT=4.0
B_MIN_4H_VOL_RATIO=0.8
B_MAX_DIST_ABOVE_EMA_FAST_PCT=6.0
B_EMA_MID_TOLERANCE_PCT=1.0
B_MIN_DIST_TO_HIGH_PCT=5.0
B_MAX_DIST_TO_HIGH_PCT=20.0
B_MAX_24H_PRICE_PCT=12.0

# C级: 4H高位突破观察
C_MAX_DIST_TO_HIGH_PCT=5.0
C_MIN_DIST_ABOVE_EMA_FAST_PCT=8.0
C_MAX_DIST_ABOVE_EMA_FAST_PCT=25.0
C_MAX_24H_PRICE_PCT=30.0

# 追高与风险过滤
WARN_DIST_ABOVE_EMA_FAST_PCT=20.0
MAX_DIST_ABOVE_EMA_FAST_PCT=35.0
MAX_ABS_FUNDING_PCT=0.25
