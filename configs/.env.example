# 企业微信群机器人 key (热点币 hype_radar/hype_form 用)
WECOM_KEY=PUT_YOUR_WECOM_KEY_HERE
# 启动雷达 binance_monitor 专属机器人 (不设则回退到 WECOM_KEY)
MONITOR_WECOM_KEY=PUT_YOUR_MONITOR_WECOM_KEY_HERE

# 扫描与推送 (SCAN_/PUSH_/MIN_CANDLE_STREAK/DIGEST_ 仅启动雷达 binance_monitor 用)
SCAN_INTERVAL_SEC=180
PUSH_INTERVAL_SEC=900
MIN_CANDLE_STREAK=2
DIGEST_MAX_COINS=20
FORM_INTERVAL_SEC=3600
REQ_TIMEOUT=8
CONCURRENCY=30

# 候选池 (启动雷达)
MIN_24H_QUOTE_VOL=5000000
TOP_N_BY_VOLUME=180

# 启动雷达信号 (binance_monitor, 慢牛型)
KLINE_INTERVAL=15m
KLINE_LIMIT=120
GAIN_24H_MIN=3.0
GAIN_24H_MAX=20.0
OI_1H_MIN_PCT=4.0
MOM_LOOKBACK=4
MOM_1H_MIN_PCT=1.5
MOM_1H_MAX_PCT=15.0
EMA_FAST=20
EMA_MID=50
EMA_SLOW=100
VOL_RECENT=4
VOL_BASELINE=20
VOL_RATIO_MIN=1.3
MAX_ABS_FUNDING_PCT=0.25
OI_PERIOD=15m
OI_LIMIT=5

# 起涨型(surge)专用: 无OI, 靠趋势
MOM4_LOOKBACK=16
MOM4_MIN_PCT=3.0
EMA_SEP_MIN_PCT=3.0

# 热点币形态强做多观察
FORM_STRONG_LONG_RSI_LO=45
FORM_STRONG_LONG_RSI_HI=55
FORM_STRONG_LONG_MIN_DIST=-3
FORM_STRONG_LONG_MAX_DIST=5
